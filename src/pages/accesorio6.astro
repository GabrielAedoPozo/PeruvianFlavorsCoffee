---
import Layout from '../layouts/Layout.astro';

const schema = {
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": "Vasos y Tazas para Café",
  "description": "Vasos doble fondo con asa y sin asa, resistente al calor. Ideal para acompañar tu café favorito. Capacidad 250ml y 450ml.",
  "brand": {
    "@type": "Brand",
    "name": "Peruvian Flavors Coffee"
  },
  "image": "https://peruvianflavorscoffee.com/taza.jpg",
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": "PEN",
    "lowPrice": "35.00",
    "highPrice": "45.00",
    "offerCount": "2",
    "availability": "https://schema.org/InStock",
    "url": "https://peruvianflavorscoffee.com/accesorio6"
  },
  "additionalProperty": [
    {
      "@type": "PropertyValue",
      "name": "Capacidad",
      "value": "250ml y 450ml"
    },
    {
      "@type": "PropertyValue",
      "name": "Material",
      "value": "Vidrio borosilicato"
    },
    {
      "@type": "PropertyValue",
      "name": "Características",
      "value": "Doble fondo, resistente al calor, con asa y sin asa"
    }
  ]
};
---

<Layout
    title="Vasos y Tazas para Café | Accesorios - Peruvian Flavors Coffee"
    description="Vasos y tazas de vidrio borosilicato doble fondo, resistente al calor. Ideal para tu café. 250ml y 450ml. Compra por WhatsApp."
    ogImage="/taza.jpg"
>
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    <div class="producto-detalle">
        <div class="back-navigation">
            <a href="/" class="back-button">
                <i class="fas fa-arrow-left"></i>
                <span>Volver al inicio</span>
            </a>
        </div>
        <div class="producto-contenido">
            <div class="producto-imagenes">
                <img src="/taza.jpg" alt="Vaso para café 450ml" class="imagen-principal">
                <div class="producto-galeria">
                    <img src="/taza.jpg" alt="Vaso grande 450ml">
                    <img src="/taza2.jpg" alt="Taza pequeña 250ml">
                </div>
            </div>
            <div class="producto-info">
                <h1>Vasos y Tazas para Café</h1>
                <p class="descripcion">
                    Vasos doble fondo con asa y sin asa, resistente al calor.
                    Ideal para acompañar tu café favorito.

                    <div class="detalles">
                        Capacidad: 250ml y 450ml<br>
                        Material: Vidrio borosilicato<br>
                        Características: Doble fondo, resistente al calor<br>
                        Disponibles con asa y sin asa
                    </div>
                </p>
                
                <div class="opciones-peso">
                    <h3>Selecciona los tamaños y cantidades:</h3>
                    <div class="peso-options-grid">
                        <div class="peso-item" data-price="35.00" data-weight="250ml">
                            <div class="peso-info">
                                <span class="weight">250ml</span>
                                <span class="price">S/. 35.00</span>
                            </div>
                            <div class="cantidad-controls">
                                <button class="btn-qty-small decrease-size" type="button">-</button>
                                <input type="number" value="0" min="0" max="10" class="qty-input" readonly inputmode="none">
                                <button class="btn-qty-small increase-size" type="button">+</button>
                            </div>
                        </div>
                        <div class="peso-item" data-price="45.00" data-weight="450ml">
                            <div class="peso-info">
                                <span class="weight">450ml</span>
                                <span class="price">S/. 45.00</span>
                            </div>
                            <div class="cantidad-controls">
                                <button class="btn-qty-small decrease-size" type="button">-</button>
                                <input type="number" value="0" min="0" max="10" class="qty-input" readonly inputmode="none">
                                <button class="btn-qty-small increase-size" type="button">+</button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="acciones">
                    <div class="total-price">
                        <span>Total: S/. <span id="total">0.00</span></span>
                    </div>
                    <a href="#" class="btn-whatsapp" id="whatsappButton">
                        <i class="fab fa-whatsapp"></i> Comprar por WhatsApp
                    </a>
                    <p class="price-disclaimer">*Precios referenciales, pueden variar de acuerdo a temporada y/o stock.</p>
                </div>
            </div>
        </div>
    </div>
</Layout>

<style>
    .producto-detalle {
        padding: 120px 2rem 4rem;
        background: radial-gradient(900px 500px at 10% 0%, rgba(197,138,75,0.10), transparent 60%) var(--color-bg);
        min-height: 100vh;
    }

    .back-navigation {
        max-width: 1200px;
        margin: 0 auto 2rem auto;
    }

    .back-button {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--color-text-soft);
        text-decoration: none;
        font-size: 0.95rem;
        padding: 0.75rem 1rem;
        border-radius: 8px;
        background: rgba(255,255,255,0.05);
        border: 1px solid var(--color-border);
        transition: all 0.3s ease;
    }

    .back-button:hover {
        color: var(--color-accent);
        background: rgba(197,138,75,0.1);
        border-color: var(--color-accent-fade);
        transform: translateX(-3px);
    }

    .back-button i {
        font-size: 1rem;
    }

    .producto-contenido {
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        color: #fff;
    }

    .producto-imagenes {
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .imagen-principal {
        width: 100%;
        border-radius: 20px;
        background: linear-gradient(150deg,#3b241a,#2b1a13);
        border: 1px solid var(--color-border);
        padding: 2rem;
        box-shadow: 0 10px 30px rgba(0,0,0,.25);
    }

    .producto-galeria {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
    }

    .producto-galeria img {
        width: 100%;
        border-radius: 10px;
        border: 1px solid rgba(255,255,255,0.08);
        cursor: pointer;
        transition: transform 0.3s ease;
        background: #281810;
        padding: 1rem;
    }

    .producto-galeria img:hover {
        transform: translateY(-2px) scale(1.02);
    }

    h1 {
        font-size: clamp(1.9rem, 4.5vw, 2.5rem);
        margin: 1rem 0;
        background: var(--grad-accent);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        color: transparent;
        font-weight: 600;
    }

    .descripcion {
        color: var(--color-text-soft);
        line-height: 1.6;
        margin: 1.5rem 0;
        font-size: .92rem;
    }

    .detalles {
        background: linear-gradient(160deg,#20130d,#180e0a);
        border: 1px solid var(--color-border);
        padding: 1.5rem;
        border-radius: 15px;
        margin: 2rem 0;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.03);
    }

    .opciones-peso {
        margin: 2rem 0;
    }
    
    .opciones-peso h3 {
        font-size: 1.3rem;
        margin-bottom: 1rem;
    }

    .peso-options-grid {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .peso-item {
        background: rgba(197,138,75,0.08);
        border: 1px solid var(--color-border);
        border-radius: 12px;
        padding: 1rem 1.2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: all .25s ease;
    }

    .peso-item:hover {
        background: rgba(197,138,75,0.12);
        border-color: rgba(197,138,75,0.4);
    }

    .peso-item.has-quantity {
        background: rgba(197,138,75,0.16);
        border-color: var(--color-accent);
        box-shadow: 0 4px 12px rgba(240,192,64,0.12);
    }

    .peso-info {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .peso-info .weight {
        font-weight: 700;
        font-size: 1.2rem;
        color: var(--color-text);
    }

    .peso-info .price {
        color: var(--color-accent);
        font-size: 1.05rem;
        font-weight: 600;
    }

    .cantidad-controls {
        display: flex;
        align-items: center;
        background: rgba(255,255,255,0.05);
        border: 1px solid var(--color-border);
        border-radius: 999px;
        padding: .25rem;
        gap: .15rem;
    }

    .btn-qty-small {
        background: none;
        border: none;
        color: var(--color-accent);
        font-size: 1.1rem;
        cursor: pointer;
        padding: .25rem .65rem;
        border-radius: 999px;
        transition: background .2s ease;
        font-weight: 600;
    }

    .btn-qty-small:hover:not(:disabled) {
        background: rgba(197,138,75,0.15);
    }

    .btn-qty-small:disabled {
        opacity: 0.3;
        cursor: not-allowed;
    }

    .qty-input {
        width: 45px;
        text-align: center;
        background: transparent;
        border: none;
        color: #fff;
        font-size: 1rem;
        font-weight: 600;
    }

    .acciones {
        display: grid;
        gap: 1rem;
        margin-top: 1.5rem;
    }

    .total-price {
        font-size: 1.3rem;
        color: var(--color-accent);
        font-weight: 700;
        background: rgba(197,138,75,0.12);
        border: 1px solid rgba(197,138,75,0.35);
        width: fit-content;
        padding: .6rem .9rem;
        border-radius: 10px;
    }

    .btn-whatsapp {
        background: linear-gradient(135deg,#2f9b5b,#247947);
        color: white;
        padding: 1rem 1.3rem;
        border-radius: 14px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .6rem;
        font-size: 1.05rem;
        font-weight: 700;
        box-shadow: 0 10px 24px rgba(34,115,63,0.35);
        transition: transform .2s ease, box-shadow .2s ease, filter .2s ease;
        width: 100%;
        max-width: 380px;
    }

    .btn-whatsapp:hover {
        transform: translateY(-2px);
        filter: brightness(1.05);
    }

    .btn-whatsapp i {
        font-size: 1.2rem;
    }

    .price-disclaimer {
        font-size: 0.8rem;
        color: var(--color-text-muted);
        margin-top: 0.5rem;
        text-align: left;
        line-height: 1.3;
        max-width: 380px;
    }

    @media (max-width: 768px) {
        .producto-contenido {
            grid-template-columns: 1fr;
            gap: 2rem;
        }

        .producto-galeria {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 620px) {
        .descripcion { font-size: .92rem; }
        .peso-options-grid { gap: .75rem; }
        .peso-item { 
            padding: .85rem 1rem; 
            flex-direction: column; 
            gap: .75rem; 
            align-items: flex-start; 
        }
        .cantidad-controls { 
            width: 100%; 
            justify-content: center; 
        }
    }

    @media (max-width: 480px) {
        .producto-detalle {
            padding: 100px 1rem 2rem;
        }

        .acciones {
            flex-direction: column;
        }

        .btn-whatsapp {
            max-width: 100%;
        }

        .peso-item { 
            padding: .75rem .85rem; 
        }
        
        .peso-info .weight { 
            font-size: 1.1rem; 
        }
        
        .peso-info .price { 
            font-size: .95rem; 
        }
    }

    @media (max-width: 360px) {
        .producto-detalle { 
            padding: 90px .75rem 1.5rem; 
        }
        
        .imagen-principal { 
            padding: 1rem; 
        }
        
        .peso-item { 
            padding: .65rem .75rem; 
        }
        
        .peso-info .weight { 
            font-size: 1rem; 
        }
        
        .qty-input { 
            width: 40px; 
            font-size: .95rem; 
        }
        
        .total-price { 
            font-size: 1rem; 
            padding: .5rem .7rem; 
        }
    }
</style>
