---
import Layout from '../layouts/Layout.astro';

const schema = {
  "@context": "https://schema.org/",
  "@type": "HowTo",
  "name": "Cómo preparar Café con Mango",
  "description": "Bebida refrescante que combina café peruano con el sabor tropical del mango. Perfecta para días calurosos.",
  "image": "https://peruvianflavorscoffee.com/mango.png",
  "totalTime": "PT10M",
  "recipeYield": "1-2 vasos"
};
---
<Layout
  title="Receta Café con Mango Refrescante | Peruvian Flavors Coffee"
  description="Descubre una fusión tropical: café peruano con mango fresco. Bebida refrescante y energizante perfecta para el verano."
  ogImage="/mango.png"
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  
  <section class="recipe">
    <div class="back-nav">
      <a href="/#recipes" class="back-button">
        <i class="fas fa-arrow-left"></i>
        <span>Volver al inicio</span>
      </a>
    </div>

    <div class="recipe-header">
      <h1>Café con Mango</h1>
      <p class="recipe-intro">
        Una fusión tropical irresistible que combina la riqueza del café peruano con la dulzura natural del mango. 
        Esta bebida refrescante es perfecta para días calurosos y te dará la energía que necesitas con un toque exótico.
      </p>
      
      <div class="recipe-meta">
        <div class="meta-item">
          <i class="fas fa-clock"></i>
          <div>
            <strong>Tiempo</strong>
            <span>10 minutos</span>
          </div>
        </div>
        <div class="meta-item">
          <i class="fas fa-signal"></i>
          <div>
            <strong>Nivel</strong>
            <span>Intermedio</span>
          </div>
        </div>
        <div class="meta-item">
          <i class="fas fa-glass-whiskey"></i>
          <div>
            <strong>Porciones</strong>
            <span>1-2 vasos</span>
          </div>
        </div>
      </div>
    </div>

    <div class="recipe-video-section">
      <h2><i class="fas fa-play-circle"></i> Video Tutorial</h2>
      <video class="recipe-video" controls playsinline preload="metadata" poster="/mango.png">
        <source src="/receta1.mp4" type="video/mp4">
        Tu navegador no soporta video HTML5.
      </video>
    </div>

    <div class="recipe-content">
      <div class="recipe-section ingredients-section">
        <h2><i class="fas fa-list-ul"></i> Ingredientes y Materiales</h2>
        <ul class="ingredients-list">
          <li><i class="fas fa-check-circle"></i> 70ml de cold brew obtenidos de (50ml de café + 500ml de agua)</li>
          <li><i class="fas fa-check-circle"></i> 70ml de concentrado de mango</li>
          <li><i class="fas fa-check-circle"></i> 70ml de agua de flor de Jamaica</li>
          <li><i class="fas fa-check-circle"></i> 10 cubos de hielo en base a cold brew</li>
          <li><i class="fas fa-check-circle"></i> Agua con gas al gusto</li>
        </ul>
      </div>

      <div class="recipe-section steps-section">
        <h2><i class="fas fa-tasks"></i> Pasos de Preparación</h2>
        <ol class="steps-list">
          <li>
            <span class="step-number">1</span>
            <div class="step-content">
              <strong>Prepara el café</strong>
              <p>Prepara el café con 50ml de café en molienda gruesa para prensa francesa y 500ml de agua, ratio 1:10 y dejárlo en la refrigeradora por 16 horas, sin bajar el émbolo, hasta que finalice el tiempo.</p>
            </div>
          </li>
          <li>
            <span class="step-number">2</span>
            <div class="step-content">
              <strong>Prepara el mango</strong>
              <p>Pela el mango maduro y lícua la cantidad sugerida 70ml</p>
            </div>
          </li>
          <li>
            <span class="step-number">3</span>
            <div class="step-content">
              <strong>Verter en un vaso</strong>
              <p>Verter en un vaso de vidrio borosilicato de 450ml el café (70ml de cold brew), agregar el concentrado de mango, los hielos al gusto y completar con agua con gas.</p>
            </div>
          </li>
        </ol>
      </div>

      <div class="recipe-section tips-section">
        <h2><i class="fas fa-star"></i> Tips de Experto</h2>
        <div class="tips-grid">
          <div class="tip-card">
            <i class="fas fa-seedling"></i>
            <h3>Mango maduro</h3>
            <p>Te recomendamos un mango dulce como el Kent.</p>
          </div>
          <div class="tip-card">
            <i class="fas fa-snowflake"></i>
            <h3>Cold brew</h3>
            <p>No te olvides de dejar tu café preparado en la prensa francesa por 16 horas en el refrigerador, sin bajar el émbolo hasta cumplir el tiempo transcurrido.</p>
          </div>
          <div class="tip-card">
            <i class="fas fa-leaf"></i>
            <h3>Alternativas saludables</h3>
            <p>Prueba con leche de coco para un toque tropical extra, o leche de almendras para menos calorías.</p>
          </div>
          <div class="tip-card">
            <i class="fas fa-plus-circle"></i>
            <h3>Variaciones</h3>
            <p>Agrega jengibre fresco para un toque picante, o vainilla para más profundidad.</p>
          </div>
        </div>
      </div>

      <div class="recipe-section benefits-section">
        <h2><i class="fas fa-heart"></i> Beneficios</h2>
        <div class="benefits-grid">
          <div class="benefit-item">
            <i class="fas fa-bolt"></i>
            <h4>Energizante</h4>
            <p>Cafeína natural del café + vitaminas del mango</p>
          </div>
          <div class="benefit-item">
            <i class="fas fa-shield-alt"></i>
            <h4>Antioxidantes</h4>
            <p>Rica en antioxidantes de ambos ingredientes</p>
          </div>
          <div class="benefit-item">
            <i class="fas fa-sun"></i>
            <h4>Vitaminas</h4>
            <p>Vitaminas A, C, E, K. Potencia el sistema inmune, ayuda la salud visual y contribuye a la coagulación sanguínea y salud ósea.</p>
          </div>
          <div class="benefit-item">
            <i class="fas fa-smile"></i>
            <h4>Digestión</h4>
            <p>Adicionalmente por su alto contenido de fibra y agua ayuda a combatir el estreñimiento y mejora la microbiota intestinal.</p>
          </div>
        </div>
      </div>
    </div>

    <div class="recipe-share">
      <h3>Comparte esta receta</h3>
      <div class="share-buttons">
        <a href="https://wa.me/?text=Mira esta receta de Café con Mango: https://peruvianflavorscoffee.com/mango" 
           target="_blank" rel="noopener" class="share-btn whatsapp">
          <i class="fab fa-whatsapp"></i> WhatsApp
        </a>
        <a href="https://www.facebook.com/sharer/sharer.php?u=https://peruvianflavorscoffee.com/mango" 
           target="_blank" rel="noopener" class="share-btn facebook">
          <i class="fab fa-facebook-f"></i> Facebook
        </a>
        <a href="https://www.instagram.com/" 
           target="_blank" rel="noopener" class="share-btn instagram">
          <i class="fab fa-instagram"></i> Instagram
        </a>
      </div>
    </div>

    <div class="back-to-home">
      <a href="/#recipes" class="home-button">
        VOLVER AL INICIO
      </a>
    </div>
  </section>
</Layout>

<style>
  .recipe {
    padding: 120px 2rem 4rem;
    max-width: 1100px;
    margin: 0 auto;
    background: radial-gradient(900px 500px at 10% 0%, rgba(197,138,75,0.10), transparent 60%) var(--color-bg);
    min-height: 100vh;
  }

  .back-nav {
    margin-bottom: 2rem;
  }

  .back-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    font-size: 0.95rem;
    text-decoration: none;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    color: var(--color-text-soft);
    background: rgba(255,255,255,0.05);
    transition: all 0.3s ease;
  }

  .back-button:hover {
    color: var(--color-accent);
    border-color: var(--color-accent-fade);
    background: rgba(197,138,75,0.12);
    transform: translateX(-3px);
  }

  .recipe-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .recipe h1 {
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    margin: 0 0 1rem;
    background: var(--grad-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    font-weight: 600;
    text-shadow: var(--text-glow);
  }

  .recipe-intro {
    color: var(--color-text-soft);
    font-size: 1.1rem;
    line-height: 1.7;
    max-width: 700px;
    margin: 0 auto 2rem;
  }

  .recipe-meta {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
    margin-top: 2rem;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.5rem;
    background: linear-gradient(135deg, rgba(197,138,75,0.08), rgba(197,138,75,0.03));
    border: 1px solid var(--color-border);
    border-radius: 12px;
  }

  .meta-item i {
    font-size: 1.5rem;
    color: var(--color-accent);
  }

  .meta-item div {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .meta-item strong {
    color: var(--color-text);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .meta-item span {
    color: var(--color-text-soft);
    font-size: 1rem;
  }

  .recipe-video-section {
    margin: 3rem 0;
  }

  .recipe-video-section h2 {
    font-size: 1.8rem;
    color: var(--color-text);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .recipe-video-section h2 i {
    color: var(--color-accent);
  }

  .recipe-video {
    width: 100%;
    aspect-ratio: 16/9;
    background: #080503;
    border: 1px solid var(--color-border-strong);
    border-radius: 20px;
    display: block;
    box-shadow: 0 20px 50px -20px rgba(0,0,0,0.7);
  }

  .recipe-content {
    display: grid;
    gap: 3rem;
    margin: 4rem 0;
  }

  .recipe-section h2 {
    font-size: 1.8rem;
    color: var(--color-text);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .recipe-section h2 i {
    color: var(--color-accent);
  }

  .ingredients-section {
    background: linear-gradient(160deg, rgba(197,138,75,0.06), rgba(197,138,75,0.02));
    padding: 2rem;
    border-radius: 16px;
    border: 1px solid var(--color-border);
  }

  .ingredients-list {
    list-style: none;
    display: grid;
    gap: 1rem;
  }

  .ingredients-list li {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 0.75rem;
    background: rgba(255,255,255,0.02);
    border-radius: 8px;
    color: var(--color-text);
    font-size: 1.05rem;
    line-height: 1.6;
  }

  .ingredients-list li i {
    color: var(--color-accent);
    margin-top: 0.2rem;
    flex-shrink: 0;
  }

  .steps-section {
    background: linear-gradient(160deg, #130a06, #0e0704);
    padding: 2rem;
    border-radius: 16px;
    border: 1px solid var(--color-border);
  }

  .steps-list {
    list-style: none;
    counter-reset: step-counter;
    display: grid;
    gap: 1.5rem;
  }

  .steps-list li {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .step-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: linear-gradient(135deg, #c58a4b, #d4a574);
    color: #27160c;
    font-weight: 700;
    font-size: 1.2rem;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .step-content {
    flex: 1;
  }

  .step-content strong {
    color: var(--color-text);
    font-size: 1.15rem;
    display: block;
    margin-bottom: 0.5rem;
  }

  .step-content p {
    color: var(--color-text-soft);
    line-height: 1.7;
    font-size: 1rem;
  }

  .tips-section {
    padding: 2rem 0;
  }

  .tips-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .tip-card {
    background: linear-gradient(135deg, rgba(197,138,75,0.1), rgba(197,138,75,0.05));
    padding: 1.5rem;
    border-radius: 12px;
    border: 1px solid var(--color-border);
    transition: all 0.3s ease;
  }

  .tip-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-accent-fade);
    box-shadow: 0 10px 30px rgba(197,138,75,0.15);
  }

  .tip-card i {
    font-size: 2rem;
    color: var(--color-accent);
    margin-bottom: 1rem;
    display: block;
  }

  .tip-card h3 {
    color: var(--color-text);
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
  }

  .tip-card p {
    color: var(--color-text-soft);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .benefits-section {
    background: linear-gradient(135deg, rgba(240, 192, 64, 0.08), rgba(240, 192, 64, 0.02));
    padding: 2rem;
    border-radius: 16px;
    border: 1px solid rgba(240, 192, 64, 0.2);
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .benefit-item {
    text-align: center;
    padding: 1.25rem;
    background: rgba(255,255,255,0.02);
    border-radius: 10px;
  }

  .benefit-item i {
    font-size: 2.5rem;
    color: var(--color-highlight);
    margin-bottom: 0.75rem;
  }

  .benefit-item h4 {
    color: var(--color-text);
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }

  .benefit-item p {
    color: var(--color-text-soft);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .recipe-share {
    text-align: center;
    padding: 3rem 2rem;
    background: linear-gradient(135deg, rgba(197,138,75,0.08), rgba(197,138,75,0.03));
    border-radius: 16px;
    border: 1px solid var(--color-border);
    margin: 3rem 0;
  }

  .recipe-share h3 {
    color: var(--color-text);
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .share-buttons {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.5rem;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 500;
    transition: all 0.3s ease;
    font-size: 0.95rem;
  }

  .share-btn.whatsapp {
    background: #25d366;
    color: white;
  }

  .share-btn.whatsapp:hover {
    background: #20ba5a;
    transform: translateY(-2px);
  }

  .share-btn.facebook {
    background: #1877f2;
    color: white;
  }

  .share-btn.facebook:hover {
    background: #166fe5;
    transform: translateY(-2px);
  }

  .share-btn.instagram {
    background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);
    color: white;
  }

  .share-btn.instagram:hover {
    opacity: 0.9;
    transform: translateY(-2px);
  }

  .back-to-home {
    text-align: center;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .home-button {
    display: inline-block;
    padding: 1rem 3rem;
    background: linear-gradient(135deg, #c58a4b, #d4a574);
    color: #27160c;
    font-weight: 700;
    font-size: 1.1rem;
    text-decoration: none;
    border-radius: 12px;
    transition: all 0.3s ease;
    letter-spacing: 0.5px;
  }

  .home-button:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 30px rgba(197,138,75,0.4);
  }

  @media (max-width: 768px) {
    .recipe {
      padding: 100px 1.5rem 3rem;
    }

    .recipe-meta {
      gap: 1rem;
    }

    .meta-item {
      padding: 0.75rem 1rem;
      font-size: 0.9rem;
    }

    .recipe-video-section h2,
    .recipe-section h2 {
      font-size: 1.5rem;
    }

    .tips-grid,
    .benefits-grid {
      grid-template-columns: 1fr;
    }

    .share-buttons {
      flex-direction: column;
      align-items: stretch;
    }

    .share-btn {
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    .recipe {
      padding: 90px 1rem 2.5rem;
    }

    .recipe h1 {
      font-size: 2rem;
    }

    .recipe-intro {
      font-size: 1rem;
    }

    .meta-item {
      flex-direction: column;
      text-align: center;
      gap: 0.5rem;
    }

    .recipe-video {
      border-radius: 12px;
    }

    .ingredients-section,
    .steps-section,
    .benefits-section {
      padding: 1.5rem;
    }
  }
</style>

