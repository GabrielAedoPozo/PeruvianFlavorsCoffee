---
import Layout from '../layouts/Layout.astro';

const schema = {
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": "Café Cusco Premium",
  "sku": "CUSCO-PREMIUM-001",
  "description": "Un señor café intenso y de notas a chocolate, guindones y con un toque final de vainilla. Café peruano de especialidad 100% orgánico de la región de Cusco-Quillabamba.",
  "brand": {
    "@type": "Brand",
    "name": "Peruvian Flavors Coffee"
  },
  "image": "https://peruvianflavorscoffee.com/cusco.png",
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": "PEN",
    "lowPrice": "32.00",
    "highPrice": "90.00",
    "offerCount": "3",
    "availability": "https://schema.org/InStock",
    "url": "https://peruvianflavorscoffee.com/producto1"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.3",
    "ratingCount": "128"
  },
  "producer": {
    "@type": "Organization",
    "name": "Productores de Cusco - Quillabamba"
  },
  "additionalProperty": [
    {
      "@type": "PropertyValue",
      "name": "Origen",
      "value": "Cusco - Quillabamba"
    },
    {
      "@type": "PropertyValue",
      "name": "Variedad",
      "value": "Bourbon y Caturra"
    },
    {
      "@type": "PropertyValue",
      "name": "Altitud",
      "value": "2100 m.s.n.m."
    },
    {
      "@type": "PropertyValue",
      "name": "Proceso",
      "value": "Lavado y fermentación 24hrs"
    },
    {
      "@type": "PropertyValue",
      "name": "Perfil en taza",
      "value": "Chocolate bitter, uvas negras, guindones y un toque de vainilla"
    }
  ]
};
---
<Layout
    title="Café Cusco Premium | Peruvian Flavors Coffee"
    description="Café Cusco de especialidad con notas a chocolate, guindones y vainilla. Origen Quillabamba. Tueste fresco y compra por WhatsApp."
    ogImage="/cusco.png"
>
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    <div class="producto-detalle">
        <div class="back-navigation">
            <a href="/" class="back-button">
                <i class="fas fa-arrow-left"></i>
                <span>Volver al inicio</span>
            </a>
        </div>
        <div class="producto-contenido">
            <div class="producto-imagenes">
                <img src="/cusco.png" alt="Café Cusco" class="imagen-principal">
            </div>
            <div class="producto-info">
                <h1>Café Cusco </h1>
                <p class="descripcion">
                    Un señor café intenso y de notas a chocolate, guindones y con un toque final de vainilla. La mejor opción para empezar la mañana súper intensa. <br><br>

                    <div class="detalles">
                        Origen: Cusco- Quillabamba<br>
                        Variedad: Bourbon y Caturra<br>
                        Altitud: 2100 m.s.n.m.<br>
                        Proceso: Lavado y fermentación 24hrs <br>
                        Perfil en taza: Chocolate bitter, uvas negras, guindones y un toque de vainilla.<br>
                        Puntaje: 86 pts.
                    </div>
                </p>
            
                <div class="opciones-peso">
                    <h3>Selecciona los tamaños y cantidades:</h3>
                    <div class="peso-options-grid">
                        <div class="peso-item" data-price="32.00" data-weight="250g">
                            <div class="peso-info">
                                <span class="weight">250gr</span>
                                <span class="price">S/. 32.00</span>
                            </div>
                            <div class="cantidad-controls">
                                <button class="btn-qty-small decrease-size" type="button">-</button>
                                <input type="number" value="0" min="0" max="10" class="qty-input" readonly inputmode="none">
                                <button class="btn-qty-small increase-size" type="button">+</button>
                            </div>
                        </div>
                        <div class="peso-item" data-price="60.00" data-weight="500g">
                            <div class="peso-info">
                                <span class="weight">500gr</span>
                                <span class="price">S/. 60.00</span>
                            </div>
                            <div class="cantidad-controls">
                                <button class="btn-qty-small decrease-size" type="button">-</button>
                                <input type="number" value="0" min="0" max="10" class="qty-input" readonly inputmode="none">
                                <button class="btn-qty-small increase-size" type="button">+</button>
                            </div>
                        </div>
                        <div class="peso-item" data-price="90.00" data-weight="1kg">
                            <div class="peso-info">
                                <span class="weight">1 Kilo</span>
                                <span class="price">S/. 90.00</span>
                            </div>
                            <div class="cantidad-controls">
                                <button class="btn-qty-small decrease-size" type="button">-</button>
                                <input type="number" value="0" min="0" max="10" class="qty-input" readonly inputmode="none">
                                <button class="btn-qty-small increase-size" type="button">+</button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="acciones">
                    <div class="total-price">
                        <span>Total: S/. <span id="total">0.00</span></span>
                    </div>
                    <a href="#" class="btn-whatsapp" id="whatsappButton">
                        <i class="fab fa-whatsapp"></i> Comprar por WhatsApp
                    </a>
                    <p class="price-disclaimer">*Precios referenciales, pueden variar de acuerdo a temporada y/o stock.</p>
                </div>
            </div>
        </div>
    </div>
</Layout>

<style>
    .producto-detalle {
        padding: 120px 2rem 4rem;
        background: radial-gradient(900px 500px at 10% 0%, rgba(197,138,75,0.10), transparent 60%) var(--color-bg);
        min-height: 100vh;
    }

    .back-navigation {
        max-width: 1200px;
        margin: 0 auto 2rem auto;
    }

    .back-button {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--color-text-soft);
        text-decoration: none;
        font-size: 0.95rem;
        padding: 0.75rem 1rem;
        border-radius: 8px;
        background: rgba(255,255,255,0.05);
        border: 1px solid var(--color-border);
        transition: all 0.3s ease;
    }

    .back-button:hover {
        color: var(--color-accent);
        background: rgba(197,138,75,0.1);
        border-color: var(--color-accent-fade);
        transform: translateX(-3px);
    }

    .back-button i {
        font-size: 1rem;
    }

    .producto-contenido {
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        color: #fff;
    }

    .producto-imagenes {
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .imagen-principal {
        width: 100%;
        border-radius: 20px;
        border: 1px solid var(--color-border);
        box-shadow: 0 10px 30px rgba(0,0,0,.25);
        background: linear-gradient(150deg,#3b241a,#2b1a13);
        padding: 2rem;
    }

    .producto-galeria {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
    }

    .producto-galeria img {
        width: 100%;
        border-radius: 10px;
        border: 1px solid rgba(255,255,255,0.08);
        cursor: pointer;
        transition: transform 0.3s ease;
        background: #281810;
    }

    .producto-galeria img:hover {
        transform: translateY(-2px) scale(1.02);
    }

    .badge {
        background: linear-gradient(95deg,#86522b,#c58a4b 70%);
        color:#27160c;
        font-weight:600;
        padding: 0.5rem 1rem;
        border-radius: 20px;
        font-size: 0.9rem;
    }

    h1 {
        font-size: clamp(1.9rem, 4.5vw, 2.5rem);
        margin: 1rem 0;
        background: var(--grad-accent);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        color: transparent;
        font-weight: 600;
    }

    .descripcion {
        color: var(--color-text-soft);
        line-height: 1.6;
        margin: 1.5rem 0;
    }

    .detalles {
        background: linear-gradient(160deg,#20130d,#180e0a);
        padding: 1.5rem;
        border-radius: 15px;
        border: 1px solid var(--color-border);
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.03);
        margin: 2rem 0;
    }

    .dots {
        display: flex;
        gap: 4px;
    }

    .dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: rgba(197,138,75,0.22);
    }

    .dot.active {
        background: var(--color-accent);
    }

    .opciones-peso {
        margin: 2rem 0;
    }

    .opciones-peso h3 {
        font-size: 1.3rem;
        margin-bottom: 1rem;
    }

    .peso-options-grid {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .peso-item {
        background: rgba(197,138,75,0.08);
        border: 1px solid var(--color-border);
        border-radius: 12px;
        padding: 1rem 1.2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: all .25s ease;
    }

    .peso-item:hover {
        background: rgba(197,138,75,0.12);
        border-color: rgba(197,138,75,0.4);
    }

    .peso-item.has-quantity {
        background: rgba(197,138,75,0.16);
        border-color: var(--color-accent);
        box-shadow: 0 4px 12px rgba(240,192,64,0.12);
    }

    .peso-info {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .peso-info .weight {
        font-weight: 700;
        font-size: 1.2rem;
        color: var(--color-text);
    }

    .peso-info .price {
        color: var(--color-accent);
        font-size: 1.05rem;
        font-weight: 600;
    }

    .cantidad-controls {
        display: flex;
        align-items: center;
        background: rgba(255,255,255,0.05);
        border: 1px solid var(--color-border);
        border-radius: 999px;
        padding: .25rem;
        gap: .15rem;
    }

    .btn-qty-small {
        background: none;
        border: none;
        color: var(--color-accent);
        font-size: 1.1rem;
        cursor: pointer;
        padding: .25rem .65rem;
        border-radius: 999px;
        transition: background .2s ease;
        font-weight: 600;
    }

    .btn-qty-small:hover:not(:disabled) {
        background: rgba(197,138,75,0.15);
    }

    .btn-qty-small:disabled {
        opacity: 0.3;
        cursor: not-allowed;
    }

    .qty-input {
        width: 45px;
        text-align: center;
        background: transparent;
        border: none;
        color: #fff;
        font-size: 1rem;
        font-weight: 600;
    }

    .peso-buttons {
        display: flex;
        gap: .8rem;
        flex-wrap: wrap;
    }

    .peso-option {
        background: rgba(197,138,75,0.06);
        border: 1px solid var(--color-border);
        border-radius: 12px;
        padding: .9rem .9rem;
        color: var(--color-text-muted);
        cursor: pointer;
        transition: all .25s ease;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .peso-option:hover {
        background: rgba(197,138,75,0.15);
        transform: translateY(-2px);
    }

    .peso-option.active {
        background: rgba(197,138,75,0.16);
        border-color: var(--color-accent);
        box-shadow: 0 6px 18px rgba(240,192,64,0.15);
        color: var(--color-text);
    }

    .peso-option .weight {
        font-weight: 700;
        font-size: 1.2rem;
        margin-bottom: 0.2rem;
    }

    .peso-option .price  {
        color: var(--color-accent);
        font-size: 1.1rem;
        font-weight: 600;
    }

    .acciones {
        display: grid;
        gap: 1rem;
        margin-top: 1.5rem;
    }

    .cantidad {
        display: inline-flex;
        align-items: center;
        background: rgba(255,255,255,0.05);
        border: 1px solid var(--color-border);
        border-radius: 999px;
        padding: .35rem;
        gap: .25rem;
        width: fit-content;
    }

    .btn-qty {
        background: none;
        border: none;
        color: var(--color-accent);
        font-size: 1.2rem;
        cursor: pointer;
        padding: .3rem .8rem;
        border-radius: 999px;
    }

    .btn-qty:hover {
        background: rgba(197,138,75,0.15);
    }

    input[type="number"] {
        width: 58px;
        text-align: center;
        background: transparent;
        border: none;
        color: #fff;
        font-size: 1.05rem;
    }

    .total-price {
        font-size: 1.3rem;
        color: var(--color-accent);
        font-weight: 700;
        background: rgba(197,138,75,0.12);
        border: 1px solid rgba(197,138,75,0.35);
        width: fit-content;
        padding: .6rem .9rem;
        border-radius: 10px;
    }

    .btn-whatsapp {
        background: linear-gradient(135deg,#2f9b5b,#247947);
        color: white;
        padding: 1rem 1.3rem;
        border-radius: 14px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .6rem;
        font-size: 1.05rem;
        font-weight: 700;
        box-shadow: 0 10px 24px rgba(34,115,63,0.35);
        transition: transform .2s ease, box-shadow .2s ease, filter .2s ease;
        width: 100%;
        max-width: 380px;
    }

    .btn-whatsapp:hover {
        filter: brightness(1.05);
    }

    .btn-whatsapp i {
        font-size: 1.2rem;
    }

    .price-disclaimer {
        font-size: 0.8rem;
        color: var(--color-text-muted);
        margin-top: 0.5rem;
        text-align: left;
        line-height: 1.3;
        max-width: 380px;
    }

    /* Galería móvil horizontal */
    @media (max-width: 620px) {
      .producto-galeria {
        display: flex;
        overflow-x: auto;
        gap: .75rem;
        scroll-snap-type: x mandatory;
        padding-bottom: .4rem;
      }
      .producto-galeria img {
        flex: 0 0 110px;
        scroll-snap-align: start;
      }
      .descripcion { font-size: .92rem; }
      .peso-options-grid { gap: .75rem; }
      .peso-item { padding: .85rem 1rem; flex-direction: column; gap: .75rem; align-items: flex-start; }
      .cantidad-controls { width: 100%; justify-content: center; }
    }

    @media (max-width: 420px) {
      .peso-item { padding: .75rem .85rem; }
      .peso-info .weight { font-size: 1.1rem; }
      .peso-info .price { font-size: .95rem; }
      .btn-whatsapp { max-width: 100%; }
    }

    @media (max-width: 768px) {
        .producto-contenido {
            grid-template-columns: 1fr;
            gap: 2rem;
        }
    }

    @media (max-width: 480px) {
        .producto-detalle {
            padding: 100px 1rem 2rem;
        }

        .acciones {
            flex-direction: column;
        }

        .cantidad {
            width: 100%;
            justify-content: center;
        }

        .btn-comprar {
            width: 100%;
        }
    }

    @media (max-width: 360px) {
      .producto-detalle { padding: 90px .75rem 1.5rem; }
      .imagen-principal { padding: 1rem; }
      .peso-item { padding: .65rem .75rem; }
      .peso-info .weight { font-size: 1rem; }
      .qty-input { width: 40px; font-size: .95rem; }
      .total-price { font-size: 1rem; padding: .5rem .7rem; }
    }
</style>



